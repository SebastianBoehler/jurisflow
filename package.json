{
  "name": "jurisflow-ai",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/SebastianBoehler/jurisflow.git"
  },
  "bugs": {
    "url": "https://github.com/SebastianBoehler/jurisflow/issues"
  },
  "homepage": "https://github.com/SebastianBoehler/jurisflow#readme",
  "packageManager": "bun@1.0.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "cd apps/web && bun run dev",
    "lint:web": "cd apps/web && bun run lint",
    "typecheck:web": "cd apps/web && bun run typecheck",
    "build:web": "cd apps/web && bun run build"
  }
}
