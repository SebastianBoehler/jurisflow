{
  "name": "jurisflow-ai",
  "private": true,
  "packageManager": "bun@1.0.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "cd apps/web && bun run dev",
    "lint:web": "cd apps/web && bun run lint",
    "typecheck:web": "cd apps/web && bun run typecheck",
    "build:web": "cd apps/web && bun run build"
  }
}
