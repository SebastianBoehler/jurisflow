POSTGRES_DB=jurisflow
POSTGRES_USER=jurisflow
POSTGRES_PASSWORD=jurisflow
DATABASE_URL=postgresql+psycopg://jurisflow:jurisflow@postgres:5432/jurisflow
REDIS_URL=redis://redis:6379/0
STORAGE_ROOT=/data/files
APP_ENV=development
ENABLE_STRUCTURED_LLM=false
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/google/gemini-2.5-flash
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Jurisflow AI
FEDERAL_LAW_API_BASE=https://api.rechtsinformationen.bund.de
EURLEX_API_BASE=https://eur-lex.europa.eu
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_BATCH_SIZE=16
EMBEDDING_CACHE_SIZE=2048
# Optional: enables Firecrawl for full-content retrieval from JS-heavy legal sites
# Get a key at https://firecrawl.dev
FIRECRAWL_API_KEY=
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
